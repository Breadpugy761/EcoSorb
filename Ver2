<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ecosorb — Biodegradable Desiccant</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Fraunces:ital,wght@0,400;0,700;0,900;1,400;1,600&display=swap" rel="stylesheet">
<style>
:root {
  --green-dark:  #1a4a2e;
  --green-mid:   #2d7a4f;
  --green-light: #4caf72;
  --green-pale:  #e8f5ed;
  --green-tint:  #f2faf5;
  --white:       #ffffff;
  --gray-50:     #f8f9f8;
  --gray-100:    #f0f1f0;
  --gray-200:    #e2e4e2;
  --gray-400:    #9ca89c;
  --gray-600:    #5a665a;
  --gray-800:    #2a322a;
  --text:        #1c241c;
  --border:      #dde5dd;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }
body { font-family: 'Manrope', sans-serif; background: var(--white); color: var(--text); overflow-x: hidden; -webkit-font-smoothing: antialiased; }

/* ── ANNOUNCEMENT BAR ───────────────────────────────── */
.announce-bar {
  background: var(--green-dark);
  color: rgba(255,255,255,0.85);
  text-align: center;
  font-size: 0.78rem;
  font-weight: 500;
  padding: 0.55rem 1rem;
  letter-spacing: 0.3px;
}
.announce-bar strong { color: #7dd99a; }

/* ── NAV ────────────────────────────────────────────── */
nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--white);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2.5rem;
  height: 64px;
  box-shadow: 0 1px 8px rgba(0,0,0,0.04);
}
.nav-logo {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: 1.35rem;
  color: var(--green-dark);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.nav-logo .logo-icon {
  width: 32px; height: 32px;
  background: var(--green-dark);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.95rem;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  list-style: none;
}
.nav-links a {
  text-decoration: none;
  color: var(--gray-600);
  font-size: 0.875rem;
  font-weight: 500;
  padding: 0.45rem 0.85rem;
  border-radius: 6px;
  transition: color 0.15s, background 0.15s;
}
.nav-links a:hover { color: var(--green-dark); background: var(--green-tint); }
.nav-right { display: flex; align-items: center; gap: 0.75rem; }
.btn-nav-cta {
  background: var(--green-dark);
  color: var(--white);
  text-decoration: none;
  font-size: 0.84rem;
  font-weight: 600;
  padding: 0.52rem 1.25rem;
  border-radius: 8px;
  transition: background 0.15s, transform 0.15s;
}
.btn-nav-cta:hover { background: var(--green-mid); transform: translateY(-1px); }

/* ── HERO ───────────────────────────────────────────── */
.hero {
  background: var(--green-tint);
  border-bottom: 1px solid var(--border);
  padding: 5rem 2.5rem 4.5rem;
  display: grid;
  grid-template-columns: 1fr 480px;
  gap: 4rem;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
}
.hero-section {
  background: var(--green-tint);
  border-bottom: 1px solid var(--border);
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  background: var(--green-pale);
  border: 1px solid #b2dfc0;
  color: var(--green-mid);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  padding: 0.35rem 0.85rem;
  border-radius: 100px;
  margin-bottom: 1.4rem;
}
.hero-badge .dot { width: 6px; height: 6px; background: var(--green-light); border-radius: 50%; }
.hero h1 {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: clamp(2.4rem, 4vw, 3.8rem);
  line-height: 1.1;
  color: var(--green-dark);
  margin-bottom: 1.2rem;
  letter-spacing: -0.5px;
}
.hero h1 em { font-style: italic; color: var(--green-mid); }
.hero-sub {
  font-size: 1.05rem;
  color: var(--gray-600);
  line-height: 1.75;
  max-width: 480px;
  margin-bottom: 2rem;
  font-weight: 400;
}
.hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; }
.btn-primary {
  background: var(--green-dark);
  color: var(--white);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
  padding: 0.8rem 1.75rem;
  border-radius: 8px;
  transition: background 0.15s, transform 0.15s;
  box-shadow: 0 2px 10px rgba(26,74,46,0.2);
}
.btn-primary:hover { background: var(--green-mid); transform: translateY(-1px); }
.btn-outline {
  color: var(--green-dark);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
  padding: 0.8rem 1.75rem;
  border-radius: 8px;
  border: 1.5px solid var(--green-dark);
  transition: background 0.15s;
}
.btn-outline:hover { background: var(--green-pale); }
.hero-trust {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--gray-600);
}
.trust-item .check { color: var(--green-light); font-size: 0.9rem; }

/* Hero product card */
.hero-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2rem;
  box-shadow: 0 8px 40px rgba(26,74,46,0.08), 0 2px 8px rgba(0,0,0,0.04);
}
.product-visual {
  background: var(--green-pale);
  border-radius: 12px;
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
  position: relative;
  overflow: hidden;
}
.product-visual::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 30% 30%, rgba(77,175,114,0.15), transparent 60%);
}
.product-orb {
  width: 130px; height: 130px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--green-mid) 0%, var(--green-dark) 100%);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  box-shadow: 0 12px 40px rgba(26,74,46,0.35);
  position: relative; z-index: 1;
}
.product-orb-name {
  font-family: 'Fraunces', serif;
  font-weight: 900; font-size: 1.5rem;
  color: var(--white); line-height: 1;
  text-align: center;
}
.product-orb-sub {
  font-size: 0.55rem;
  color: rgba(255,255,255,0.7);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-top: 0.2rem;
}
.product-meta { padding-top: 0.5rem; }
.product-name {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.25rem;
}
.product-desc {
  font-size: 0.83rem;
  color: var(--gray-600);
  line-height: 1.6;
  margin-bottom: 1rem;
}
.product-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }
.tag {
  background: var(--green-pale);
  color: var(--green-mid);
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.25rem 0.65rem;
  border-radius: 100px;
  border: 1px solid #b2dfc0;
}
.product-perf {
  background: var(--gray-50);
  border-radius: 8px;
  padding: 0.9rem 1rem;
  display: flex;
  justify-content: space-between;
}
.perf-item { text-align: center; }
.perf-val { font-size: 1.1rem; font-weight: 800; color: var(--green-dark); display: block; }
.perf-label { font-size: 0.68rem; color: var(--gray-400); margin-top: 0.1rem; font-weight: 500; }

/* ── STATS BAR ──────────────────────────────────────── */
.stats-bar {
  background: var(--white);
  border-bottom: 1px solid var(--border);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}
.stat-item {
  padding: 1.75rem 2rem;
  border-right: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 1rem;
  justify-content: center;
}
.stat-item:last-child { border-right: none; }
.stat-icon {
  width: 44px; height: 44px;
  background: var(--green-pale);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}
.stat-text .stat-num {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: 1.6rem;
  color: var(--green-dark);
  display: block;
  line-height: 1.1;
}
.stat-text .stat-label {
  font-size: 0.78rem;
  color: var(--gray-600);
  margin-top: 0.15rem;
  line-height: 1.4;
}

/* ── SHARED SECTION STYLES ──────────────────────────── */
.section-wrap { max-width: 1200px; margin: 0 auto; padding: 5rem 2.5rem; }
.section-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--green-mid);
  margin-bottom: 0.6rem;
}
.section-title {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: clamp(1.7rem, 2.8vw, 2.5rem);
  line-height: 1.15;
  color: var(--green-dark);
  margin-bottom: 0.9rem;
  letter-spacing: -0.3px;
}
.section-title em { font-style: italic; color: var(--green-mid); }
.section-lead {
  font-size: 1rem;
  color: var(--gray-600);
  line-height: 1.75;
  max-width: 540px;
  margin-bottom: 2.5rem;
}

/* ── PROBLEM ────────────────────────────────────────── */
.problem-section { background: var(--white); border-bottom: 1px solid var(--border); }
.problem-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
}
.problem-text p {
  font-size: 0.95rem;
  color: var(--gray-600);
  line-height: 1.8;
  margin-bottom: 1rem;
}
.problem-text p strong { color: var(--text); font-weight: 600; }
.stat-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
.stat-card {
  background: var(--gray-50);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.3rem;
}
.stat-card .big-num {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: 2.1rem;
  color: var(--green-dark);
  line-height: 1;
  display: block;
}
.stat-card .unit-label {
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--green-mid);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.15rem;
  display: block;
}
.stat-card .desc {
  font-size: 0.78rem;
  color: var(--gray-400);
  line-height: 1.5;
  margin-top: 0.3rem;
}
.expert-quote {
  margin-top: 1.5rem;
  padding: 1.25rem 1.5rem;
  background: var(--green-tint);
  border-left: 3px solid var(--green-light);
  border-radius: 0 8px 8px 0;
}
.expert-quote p { font-size: 0.87rem; color: var(--gray-600); line-height: 1.65; font-style: italic; }
.expert-quote cite { font-size: 0.76rem; color: var(--green-mid); font-style: normal; font-weight: 600; margin-top: 0.5rem; display: block; }

/* ── SOLUTION ───────────────────────────────────────── */
.solution-section { background: var(--gray-50); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.ingredient-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
.ing-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.6rem;
  transition: box-shadow 0.2s, transform 0.2s;
}
.ing-card:hover { box-shadow: 0 6px 24px rgba(26,74,46,0.1); transform: translateY(-2px); }
.ing-pct {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: 2.4rem;
  color: var(--green-dark);
  line-height: 1;
  margin-bottom: 0.4rem;
}
.ing-name { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
.ing-desc { font-size: 0.82rem; color: var(--gray-600); line-height: 1.65; margin-bottom: 0.9rem; }
.tag-row { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.benefit-strip {
  background: var(--green-dark);
  border-radius: 12px;
  padding: 1.4rem 1.8rem;
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  align-items: center;
  justify-content: space-between;
}
.benefit-item { display: flex; align-items: center; gap: 0.5rem; }
.benefit-item .check-circle {
  width: 22px; height: 22px;
  background: rgba(77,175,114,0.25);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.65rem; color: #7dd99a; font-weight: 700;
}
.benefit-item span { font-size: 0.84rem; color: rgba(255,255,255,0.85); font-weight: 500; }

/* ── RESULTS ────────────────────────────────────────── */
.results-section { background: var(--white); border-bottom: 1px solid var(--border); }
.result-hero-card {
  background: var(--green-dark);
  border-radius: 14px;
  padding: 2rem 2.5rem;
  display: flex;
  align-items: center;
  gap: 2rem;
  margin-bottom: 1.5rem;
}
.result-big-num {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: 4rem;
  color: #7dd99a;
  line-height: 1;
  white-space: nowrap;
}
.result-hero-text strong { display: block; color: var(--white); font-size: 1rem; margin-bottom: 0.4rem; font-weight: 700; }
.result-hero-text p { color: rgba(255,255,255,0.6); font-size: 0.85rem; line-height: 1.6; }
.results-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
.result-card {
  background: var(--gray-50);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
}
.result-card h3 { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
.result-card p { font-size: 0.83rem; color: var(--gray-600); line-height: 1.65; }
.result-highlight {
  margin-top: 0.9rem;
  background: var(--green-pale);
  border-radius: 6px;
  padding: 0.65rem 0.9rem;
  font-size: 0.78rem;
  color: var(--green-mid);
  font-weight: 600;
  border: 1px solid #b2dfc0;
}

/* ── MARKET ─────────────────────────────────────────── */
.market-section { background: var(--gray-50); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.tam-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
.tam-card {
  border-radius: 12px;
  padding: 1.7rem 1.5rem;
  position: relative;
  overflow: hidden;
}
.tam-card.tam { background: var(--green-dark); }
.tam-card.sam { background: var(--green-mid); }
.tam-card.som { background: var(--green-light); }
.tam-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.6); margin-bottom: 0.7rem; }
.tam-val { font-family: 'Fraunces', serif; font-weight: 900; font-size: 2.5rem; color: var(--white); line-height: 1; margin-bottom: 0.4rem; }
.tam-desc { font-size: 0.79rem; color: rgba(255,255,255,0.65); line-height: 1.5; }
.cagr-note {
  text-align: center;
  font-size: 0.84rem;
  color: var(--gray-600);
  padding: 1rem;
  background: var(--white);
  border-radius: 8px;
  border: 1px solid var(--border);
}
.cagr-note strong { color: var(--green-mid); }

/* ── CUSTOMERS ──────────────────────────────────────── */
.customers-section { background: var(--white); border-bottom: 1px solid var(--border); }
.cust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
.cust-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.4rem;
  transition: border-color 0.2s, transform 0.2s;
}
.cust-card:hover { border-color: var(--green-light); transform: translateY(-2px); }
.cust-status {
  display: inline-block;
  font-size: 0.67rem;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  padding: 0.2rem 0.65rem;
  border-radius: 100px;
  margin-bottom: 0.8rem;
}
.s-promising { background: var(--green-pale); color: var(--green-mid); }
.s-target { background: #e3f2fd; color: #1565c0; }
.s-outreach { background: #fff3e0; color: #e65100; }
.s-validated { background: #f3e5f5; color: #6a1b9a; }
.cust-card h3 { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
.cust-card p { font-size: 0.8rem; color: var(--gray-600); line-height: 1.6; }
.survey-strip {
  background: var(--gray-50);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem 2rem;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  divide-x: 1px solid var(--border);
  gap: 1.5rem;
}
.sv-item { text-align: center; padding: 0.5rem 0; }
.sv-item + .sv-item { border-left: 1px solid var(--border); }
.sv-pct { font-family: 'Fraunces', serif; font-weight: 900; font-size: 2rem; color: var(--green-dark); display: block; }
.sv-label { font-size: 0.78rem; color: var(--gray-600); line-height: 1.45; margin-top: 0.2rem; }

/* ── ROADMAP ────────────────────────────────────────── */
.roadmap-section { background: var(--gray-50); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.step-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  position: relative;
}
.step-time {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--green-mid);
  margin-bottom: 0.6rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.step-time::before {
  content: '';
  width: 6px; height: 6px;
  background: var(--green-light);
  border-radius: 50%;
  display: inline-block;
}
.step-card h3 { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
.step-card p { font-size: 0.8rem; color: var(--gray-600); line-height: 1.65; }

/* ── TEAM ───────────────────────────────────────────── */
.team-section { background: var(--white); border-bottom: 1px solid var(--border); }
.team-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1rem; margin-top: 2rem; }
.team-member { text-align: center; }
.avatar {
  width: 72px; height: 72px; border-radius: 50%;
  background: var(--green-pale);
  border: 2px solid var(--border);
  margin: 0 auto 0.65rem;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fraunces', serif;
  font-weight: 900; font-size: 1.3rem;
  color: var(--green-dark);
}
.team-member .name { font-size: 0.84rem; font-weight: 600; color: var(--text); }

/* ── CTA / CONTACT ──────────────────────────────────── */
.cta-section {
  background: var(--green-dark);
  padding: 5.5rem 2.5rem;
  text-align: center;
}
.cta-inner { max-width: 640px; margin: 0 auto; }
.cta-eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: rgba(255,255,255,0.45);
  margin-bottom: 1rem;
}
.cta-heading {
  font-family: 'Fraunces', serif;
  font-weight: 900;
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 1rem;
}
.cta-heading em { font-style: italic; color: #7dd99a; }
.cta-sub { font-size: 1rem; color: rgba(255,255,255,0.55); line-height: 1.7; margin-bottom: 2rem; }
.btn-cta-primary {
  background: #7dd99a;
  color: var(--green-dark);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 700;
  padding: 0.9rem 2rem;
  border-radius: 8px;
  transition: background 0.15s, transform 0.15s;
  display: inline-block;
}
.btn-cta-primary:hover { background: #a0e8b5; transform: translateY(-1px); }
.cta-footnotes { display: flex; gap: 1.5rem; justify-content: center; margin-top: 1.8rem; flex-wrap: wrap; }
